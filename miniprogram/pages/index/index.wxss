
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx;
}

.header {
  background: white;
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.1);
}

.header-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.status-text {
  font-size: 28rpx;
  color: #28a745;
  margin-bottom: 30rpx;
}

.status-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.status-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 30rpx;
  border-radius: 24rpx;
  text-align: center;
}

.status-card.positive {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}

.status-card.negative {
  background: linear-gradient(135deg, #eb3349 0%, #f45c43 100%);
}

.card-label {
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 10rpx;
}

.card-value {
  font-size: 44rpx;
  font-weight: bold;
}

.panel {
  background: white;
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.1);
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 4rpx solid #eee;
}

.panel-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.refresh-btn {
  font-size: 40rpx;
  padding: 10rpx;
}

.loading, .empty {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

.position-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.position-item {
  display: grid;
  grid-template-columns: 120rpx 140rpx 80rpx 180rpx 140rpx;
  align-items: center;
  gap: 10rpx;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.pos-name {
  font-weight: bold;
  color: #333;
}

.pos-price {
  color: #666;
}

.pos-position {
  text-align: center;
  font-weight: bold;
}

.pos-pnl {
  font-weight: bold;
  text-align: right;
}

.pnl-positive {
  color: #28a745;
}

.pnl-negative {
  color: #dc3545;
}

.pnl-zero {
  color: #666;
}

.signal {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 40rpx;
  font-weight: bold;
  font-size: 22rpx;
  text-align: center;
}

.signal-watch {
  background: #e9ecef;
  color: #495057;
}

.signal-long {
  background: #d4edda;
  color: #155724;
}

.signal-short {
  background: #f8d7da;
  color: #721c24;
}

.portfolio-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.portfolio-item {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
}

.port-name {
  font-weight: bold;
  color: #333;
  font-size: 30rpx;
  margin-bottom: 10rpx;
}

.port-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  font-size: 24rpx;
  color: #666;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
}

.hist-time {
  color: #999;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.hist-content {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
